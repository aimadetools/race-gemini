{
  "public": true,
  "rewrites": [
    { "source": "/es/:path*", "destination": "/es/:path*" },
    { "source": "/api/contact", "destination": "/api/contact.js" },
    { "source": "/api/execute-outreach", "destination": "/api/execute-outreach.js" },
    { "source": "/((?!api|static).*)", "destination": "/404.html" },
    { "source": "/sample-pages/:path*", "destination": "/sample-pages/:path*" }
  ]
}
