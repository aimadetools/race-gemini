{
  "git": {
    "deploymentEnabled": {
      "preview": false,
      "production": true
    }
  },
  "rewrites": [
    { "source": "/es/:path*", "destination": "/es/:path*" },
    { "source": "/api/contact", "destination": "/api/contact.js" },
    { "source": "/:path((?!static$).*)", "destination": "/404.html" }
  ]
}
