<?php
/**
 * Plugin Name: LocalLeads SEO Pages
 * Description: Dynamically serve search-optimized local landing pages generated by LocalLeads.
 * Version: 1.0.0
 * Author: LocalLeads
 * Author URI: https://www.localseogen.com
 */

if ( ! defined( 'ABSPATH' ) ) {
    exit; // Exit if accessed directly.
}

// Default settings
define( 'LOCALLEADS_CLIENT_ID', '%%CLIENT_ID%%' );
define( 'LOCALLEADS_API_URL', 'https://www.localseogen.com' );

class LocalLeadsSEO {
    public function __construct() {
        add_action( 'init', array( $this, 'register_rewrite_rules' ) );
        add_action( 'query_vars', array( $this, 'register_query_vars' ) );
        add_action( 'template_redirect', array( $this, 'handle_page_routing' ) );
        add_action( 'admin_menu', array( $this, 'add_settings_page' ) );
        add_action( 'admin_init', array( $this, 'register_settings' ) );
        add_action( 'update_option_localleads_url_prefix', 'flush_rewrite_rules' );
    }

    public function register_rewrite_rules() {
        $prefix = get_option( 'localleads_url_prefix', 'local' );
        // Match: yoursite.com/local/service-in-town.html
        add_rewrite_rule(
            '^' . $prefix . '/([^/]+)\.html$',
            'index.php?localleads_page=$matches[1]',
            'top'
        );
    }

    public function register_query_vars( $vars ) {
        $vars[] = 'localleads_page';
        return $vars;
    }

    public function handle_page_routing() {
        $page_name = get_query_var( 'localleads_page' );
        if ( ! $page_name ) {
            return;
        }

        $client_id = get_option( 'localleads_client_id', LOCALLEADS_CLIENT_ID );
        if ( ! $client_id || $client_id === '%%CLIENT_ID%%' ) {
            return; // Not configured
        }

        // URL of the generated page on LocalLeads
        $url = LOCALLEADS_API_URL . '/' . $client_id . '/' . $page_name . '.html';

        $response = wp_remote_get( $url, array(
            'timeout'   => 15,
            'sslverify' => true,
        ) );

        if ( is_wp_error( $response ) ) {
            return; // Let WordPress handle 404/error
        }

        $code = wp_remote_retrieve_response_code( $response );
        if ( $code !== 200 ) {
            return; // Let WordPress handle 404/error
        }

        $html = wp_remote_retrieve_body( $response );

        // Serve the HTML directly
        header( 'Content-Type: text/html; charset=utf-8' );
        echo $html;
        exit;
    }

    public function add_settings_page() {
        add_options_page(
            'LocalLeads SEO Settings',
            'LocalLeads SEO',
            'manage_options',
            'localleads-seo',
            array( $this, 'render_settings_page' )
        );
    }

    public function register_settings() {
        register_setting( 'localleads_settings_group', 'localleads_client_id' );
        register_setting( 'localleads_settings_group', 'localleads_url_prefix' );
    }

    public function render_settings_page() {
        $client_id = get_option( 'localleads_client_id', LOCALLEADS_CLIENT_ID );
        $prefix = get_option( 'localleads_url_prefix', 'local' );
        
        $connection_status = 'Unknown';
        $connection_color = '#666';
        
        if ( $client_id && $client_id !== '%%CLIENT_ID%%' ) {
            $check_url = LOCALLEADS_API_URL . '/' . $client_id . '/sitemap.xml';
            $response = wp_remote_get( $check_url, array( 'timeout' => 5 ) );
            if ( ! is_wp_error( $response ) && wp_remote_retrieve_response_code( $response ) === 200 ) {
                $connection_status = 'Connected';
                $connection_color = '#46b450';
            } else {
                $connection_status = 'Invalid Client ID or No Pages Generated';
                $connection_color = '#dc3232';
            }
        } else {
            $connection_status = 'Not Configured';
            $connection_color = '#d54e21';
        }
        ?>
        <div class="wrap">
            <h1>LocalLeads SEO Pages Settings</h1>
            <p>Welcome to LocalLeads! This plugin automatically serves your search-optimized landing pages under your own WordPress domain.</p>
            
            <div style="background: #fff; border-left: 4px solid <?php echo $connection_color; ?>; padding: 12px; margin: 20px 0; box-shadow: 0 1px 1px 0 rgba(0,0,0,.1);">
                <strong>Status:</strong> <span style="color: <?php echo $connection_color; ?>; font-weight: bold;"><?php echo esc_html( $connection_status ); ?></span>
            </div>

            <form method="post" action="options.php">
                <?php settings_fields( 'localleads_settings_group' ); ?>
                <table class="form-table">
                    <tr valign="top">
                        <th scope="row">LocalLeads Client ID (UUID)</th>
                        <td>
                            <input type="text" name="localleads_client_id" value="<?php echo esc_attr( $client_id ); ?>" style="width: 400px; font-family: monospace;" />
                            <p class="description">Your unique account identifier. If you downloaded this plugin from your dashboard, this is already configured.</p>
                        </td>
                    </tr>
                    <tr valign="top">
                        <th scope="row">URL Prefix</th>
                        <td>
                            <input type="text" name="localleads_url_prefix" value="<?php echo esc_attr( $prefix ); ?>" />
                            <p class="description">The URL prefix where pages will be served (e.g., entering <code>local</code> serves pages at <code>example.com/local/service-in-town.html</code>).</p>
                        </td>
                    </tr>
                </table>
                <?php submit_button(); ?>
            </form>
            <hr />
            <h2>Need help?</h2>
            <p>1. Go to your <a href="https://www.localseogen.com/dashboard.html" target="_blank">LocalLeads Dashboard</a> to view your pages and credits.</p>
            <p>2. If you change your URL Prefix, make sure to visit your WordPress <a href="<?php echo admin_url('options-permalink.php'); ?>">Permalinks page</a> once to flush rewrite rules.</p>
        </div>
        <?php
    }
}

// Flush rewrite rules on activation and deactivation
function localleads_seo_activate() {
    $plugin = new LocalLeadsSEO();
    $plugin->register_rewrite_rules();
    flush_rewrite_rules();
}
register_activation_hook( __FILE__, 'localleads_seo_activate' );

function localleads_seo_deactivate() {
    flush_rewrite_rules();
}
register_deactivation_hook( __FILE__, 'localleads_seo_deactivate' );

// Start the plugin
new LocalLeadsSEO();
