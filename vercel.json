{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/free-seo-audit.html",
      "destination": "/audit.html",
      "permanent": true
    },
    {
      "source": "/agency-signup.html",
      "destination": "/agency-partnerships.html",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/auth.html",
      "permanent": true
    },
    {
      "source": "/book-a-demo",
      "destination": "/contact.html?reason=demo",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/share/:hash",
      "destination": "/share.html?token=:hash"
    },
    {
      "source": "/generated-seo-pages/:fileName",
      "destination": "/api/serve-static-page?fileName=:fileName"
    },
    {
      "source": "/agency/:slug",
      "destination": "/api/agency-profile?slug=:slug"
    },
    {
      "source": "/:clientId(\\d+)/:fileName",
      "destination": "/api/[[...slug]]?slug=:clientId&slug=:fileName"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/[[...slug]]?slug=custom&slug=sitemap.xml"
    },
    {
      "source": "/:fileName([^/]+\\.html)",
      "destination": "/api/[[...slug]]?slug=custom&slug=:fileName"
    }
  ]
}